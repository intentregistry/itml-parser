{
  "name": "@intent/itml-parser-wasm",
  "version": "0.1.0",
  "description": "ITML v0.1 parser, formatter, and linter compiled to WebAssembly",
  "main": "pkg/itml_parser.js",
  "types": "pkg/itml_parser.d.ts",
  "files": [
    "pkg/"
  ],
  "scripts": {
    "build": "wasm-pack build --target bundler --out-dir pkg --features wasm",
    "build-node": "wasm-pack build --target nodejs --out-dir pkg --features wasm",
    "build-web": "wasm-pack build --target web --out-dir pkg --features wasm",
    "test": "wasm-pack test --headless --firefox"
  },
  "keywords": [
    "itml",
    "parser",
    "formatter",
    "linter",
    "intent",
    "markup",
    "webassembly",
    "wasm"
  ],
  "author": "Intent Ecosystem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/intent-ecosystem/itml-parser.git"
  },
  "bugs": {
    "url": "https://github.com/intent-ecosystem/itml-parser/issues"
  },
  "homepage": "https://github.com/intent-ecosystem/itml-parser#readme",
  "itmlSpec": "0.1",
  "devDependencies": {
    "wasm-pack": "^0.12.0"
  }
}
